# Database
DATABASE_URL=postgresql://postgres:password@localhost/aurum

# JWT
SECRET_KEY=change-this-to-a-long-random-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# MT5
MT5_LOGIN=187970
MT5_PASSWORD=your_password
MT5_SERVER=MEXGlobalFinancial-Real
SYMBOL=XAUUSD

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=your@gmail.com

# Admin bootstrap (created on first startup if not exists)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_NAME=Admin
